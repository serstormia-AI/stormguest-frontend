# =============================================================
# stormguest-frontend — Variables de Entorno (Vite)
# Copiá este archivo como .env y completá los valores reales.
# Las variables VITE_* son expuestas al bundle del navegador.
# NUNCA pongas aquí claves privadas o Service Role Keys.
# =============================================================


# -------------------------------------------------------------
# SUPABASE (cliente público)
# Usado por src/lib/supabase.js para conectar al proyecto Supabase
# Estos valores son PÚBLICOS (anon key tiene RLS habilitado)
# Obtené los valores en: Supabase → Project Settings → API
# -------------------------------------------------------------

# URL del proyecto (ej: https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=https://[TU_PROJECT_REF].supabase.co

# Anon/Public Key (segura para exponer en el browser, respeta RLS)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -------------------------------------------------------------
# BACKEND API
# Usado por src/services/api.js como base URL para llamadas al backend
# En desarrollo apunta al servidor Express local
# En producción apunta a tu dominio del backend
# -------------------------------------------------------------

# URL base de la API (sin trailing slash)
VITE_API_URL=http://localhost:3001/api

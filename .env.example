# =============================================================
# stormguest-frontend — Variables de Entorno (Vite)
# Copiá este archivo como .env y completá los valores reales.
# Las variables VITE_* quedan expuestas en el bundle del navegador.
# NUNCA pongas aquí claves privadas ni Service Role Keys.
# =============================================================


# -------------------------------------------------------------
# BACKEND API
# Usado por src/services/api.js como base URL para llamadas al backend
# En producción apunta a tu dominio de Railway u otro host
# -------------------------------------------------------------

VITE_API_URL=https://tu-backend.railway.app/api


# -------------------------------------------------------------
# SUPABASE (cliente público)
# Usado por src/lib/supabase.js para Realtime y consultas directas
# La anon key es segura en el browser — Supabase aplica RLS
# Supabase → Project Settings → API
# -------------------------------------------------------------

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key
